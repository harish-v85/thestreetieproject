# Supabase — Project Settings
#
# URL: General → Project ID (ref) → build: https://YOUR_PROJECT_REF.supabase.co
#   Or copy "Project URL" if you see it under API / Data API.
#
# Key: API Keys → Publishable key (safe for the browser; may start with sb_publishable_...)
#   Paste it below. The env name stays ANON_KEY because the Supabase client expects it here.
#
# Do NOT put the Secret key in any NEXT_PUBLIC_ variable.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_key_here

# Server-only: Super Admin "Users" page (create/edit accounts via Auth Admin API).
# Supabase → Project Settings → API → Secret key (service_role). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_here

# Cloudinary — dog photo uploads (server only; never expose to the browser or NEXT_PUBLIC_*).
# Dashboard → API Keys → copy the full “API environment variable” line (it includes the secret).
# Folder "streetie/dogs" is used automatically.
#
# Option A — one line (recommended; matches the dashboard):
# CLOUDINARY_URL=cloudinary://YOUR_API_KEY:YOUR_API_SECRET@YOUR_CLOUD_NAME
#
# Option B — three variables (same values as in the URL):
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
